          "body": "{\n  \"message\": \"Invoice marked as paid successfully\",\n  \"invoice\": {\n    \"id\": \"uuid\",\n    \"invoice_number\": \"PLAT-2024-001\",\n    \"status\": \"paid\",\n    \"paid_amount\": \"2948.82\",\n    \"balance_due\": \"0.00\",\n    \"payment_date\": \"2024-05-15\",\n    \"payment_method\": \"bank_transfer\",\n    \"transaction_id\": \"NEFT123456\"\n  }\n}"
        }
      ]
    },
